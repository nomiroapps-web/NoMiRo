# ═══════════════════════════════════════════════════════════
#  NoMiRo — Production Environment Variables
#  Copy to .env and fill in your values.
#  ⚠  VITE_* vars are baked into the JS bundle at BUILD TIME.
#     Change them → you must rebuild the app.
# ═══════════════════════════════════════════════════════════

# ── Server (Node.js) ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Backend mode ──────────────────────────────────────────
# "cloud"  → Supabase (managed or self-hosted)
# "local"  → IndexedDB + OIDC (fully offline-capable)
VITE_BACKEND_MODE=local

# ── Cloud mode — Supabase ─────────────────────────────────
# Only when VITE_BACKEND_MODE=cloud
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_SUPABASE_PROJECT_ID=your-project-id

# ── Local mode — OIDC provider ────────────────────────────
# Only when VITE_BACKEND_MODE=local
# Works with Keycloak, Auth0, Authentik, Zitadel, Kanidm, ...
VITE_OIDC_AUTHORITY=https://auth.example.com/realms/nomiro
VITE_OIDC_CLIENT_ID=nomiro-web
VITE_OIDC_REDIRECT_URI=https://yourdomain.com/auth/callback
VITE_OIDC_POST_LOGOUT_URI=https://yourdomain.com
VITE_OIDC_SCOPE=openid profile email

# ── Push notifications (Web Push / VAPID) ─────────────────
# Generate: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY goes in the frontend build (safe to expose)
# VAPID_PRIVATE_KEY + VAPID_PUBLIC_KEY go in Supabase secrets
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── Email — open-source SMTP ──────────────────────────────
# Set these as Supabase secrets, not in .env
# Works with: Postfix, Gmail (app password), Brevo free, Mailpit (local dev)
#
#   supabase secrets set \
#     SMTP_HOST=smtp.example.com \
#     SMTP_PORT=587 \
#     SMTP_USER=you@example.com \
#     SMTP_PASS=yourpassword \
#     SMTP_FROM="NoMiRo <noreply@yourdomain.com>" \
#     SMTP_SECURE=false

# ── Supabase edge functions ───────────────────────────────
# Set via: supabase secrets set KEY=value
#
#   EMAIL_WEBHOOK_SECRET    – HMAC secret for auth-email-hook
#   ALLOWED_ORIGINS         – comma-separated extra CORS origins
#   APP_URL                 – https://yourdomain.com
#   APP_DOMAIN              – yourdomain.com
#   EMAIL_SENDER_DOMAIN     – notify.yourdomain.com (or yourdomain.com)
#   SITE_NAME               – nomiro (shown in email templates)
#   VAPID_PRIVATE_KEY       – from web-push generate-vapid-keys
#   VAPID_PUBLIC_KEY        – same as VITE_VAPID_PUBLIC_KEY
#   VAPID_SUBJECT           – mailto:admin@yourdomain.com
